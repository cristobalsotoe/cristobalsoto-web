---
import { getEntry } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { WORK } from "@consts"

// Obtenemos específicamente tu archivo cv.md de la colección "work"
const cvEntry = await getEntry("work", "cv")
const { Content, headings } = await cvEntry.render()
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
    </div>
  </TopLayout>
  
 <BottomLayout>
    <div class="relative mt-4 animate">
      
      <aside class="hidden lg:block absolute right-full top-0 w-56 pr-8 h-full z-10">
        <div class="sticky top-24">
          <p class="font-semibold text-black dark:text-white mb-4 uppercase tracking-wider text-sm">
            Índice
          </p>
          <ul class="space-y-3 border-l border-black/10 dark:border-white/10 pl-4 text-left">
            {headings
              .filter((heading) => heading.depth === 2)
              .map((heading) => (
                <li>
                  <a 
                    href={`#${heading.slug}`} 
                    class="text-sm text-black/70 dark:text-white/70 hover:text-blue-600 dark:hover:text-blue-400 transition-colors block"
                  >
                    {heading.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </aside>

      <article class="prose dark:prose-invert max-w-none w-full">
        <Content />
      </article>

    </div>
  </BottomLayout>
</PageLayout>