---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import { BLOG } from "@consts"
import { formatDate, readingTime } from "@lib/utils"

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const today = new Date().toLocaleDateString("es-CL", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
})
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <div class="ident-blog flex-1 -mb-px">
    <div class="mx-auto max-w-screen-lg px-5 pt-28 pb-20">

      <!-- masthead de diario -->
      <header class="text-center mb-10">
        <div class="masthead-rule mb-5"></div>
        <p class="kicker mb-2">Notas de hidrología, clima y datos</p>
        <h1 class="news-headline text-6xl md:text-7xl">El Pluviómetro</h1>
        <div class="flex items-center justify-center gap-4 mt-4 font-mono text-[0.65rem] uppercase tracking-[0.14em]" style="color: var(--news-faint);">
          <span>{today}</span>
          <span aria-hidden="true">·</span>
          <span>Temuco — Irvine</span>
          <span aria-hidden="true">·</span>
          <span>por Cristóbal Soto-Escobar</span>
        </div>
        <div class="masthead-rule mt-5" style="transform: scaleY(-1);"></div>
      </header>

      <!-- todas las notas: lista vertical, misma estructura que el destacado -->
      <div class="space-y-10">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="news-link block group">
            <article class:list={["pb-10", post.data.image && "grid md:grid-cols-[1fr_16rem] gap-8 items-start"]} style="border-bottom: 1px solid var(--news-line);">
              <div>
                <p class="kicker mb-3">{post.data.source ?? "Nota"}</p>
                <h2 class="news-headline text-4xl md:text-5xl transition-colors duration-300">
                  {post.data.title}
                </h2>
                <p class="mt-4 text-lg leading-relaxed max-w-2xl" style="color: var(--news-gray);">
                  {post.data.summary}
                </p>
                <div class="flex flex-wrap gap-x-4 gap-y-1 mt-4 font-mono text-[0.65rem] uppercase tracking-[0.14em]" style="color: var(--news-faint);">
                  <span>{formatDate(post.data.date)}</span>
                  <span>{readingTime(post.body)}</span>
                </div>
              </div>
              {post.data.image && (
                <img src={post.data.image} alt="" class="w-full border" style="border-color: var(--news-line);" loading="lazy" />
              )}
            </article>
          </a>
        ))}
      </div>

    </div>
  </div>
</PageLayout>
