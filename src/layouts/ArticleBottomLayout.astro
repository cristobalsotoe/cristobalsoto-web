---
import { type CollectionEntry, getCollection } from "astro:content"

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">
}

const { entry } = Astro.props
const { collection } = entry
const { Content } = await entry.render()

const items = (await getCollection(collection))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
const index = items.findIndex(x => x.slug === entry.slug)
const prev = items[(index - 1 + items.length) % items.length]
const next = items[(index + 1) % items.length]
const hasNav = items.length > 1
---

<div>
  <article>
    <Content/>
  </article>
  {hasNav && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-12 pt-8 border-t" style="border-color: var(--paper-line);">
      <a href={`/${prev.collection}/${prev.slug}`} class="group p-4 gap-1 flex flex-col border rounded transition-colors hover:bg-paper-raised" style="border-color: var(--paper-line);">
        <span class="label" style="color: var(--ink-faint);">Anterior</span>
        <span class="serif italic text-lg group-hover:text-river-deep transition-colors" style="color: var(--ink);">{prev.data.title}</span>
      </a>
      <a href={`/${next.collection}/${next.slug}`} class="group p-4 gap-1 flex flex-col sm:items-end border rounded transition-colors hover:bg-paper-raised" style="border-color: var(--paper-line);">
        <span class="label" style="color: var(--ink-faint);">Siguiente</span>
        <span class="serif italic text-lg group-hover:text-river-deep transition-colors sm:text-right" style="color: var(--ink);">{next.data.title}</span>
      </a>
    </div>
  )}
</div>
