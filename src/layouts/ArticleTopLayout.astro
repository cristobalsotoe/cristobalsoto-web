---
import type { CollectionEntry } from "astro:content"
import { formatDate, readingTime } from "@lib/utils"

type Props = {
  entry: CollectionEntry<"projects"> | CollectionEntry<"blog">
}

const { entry } = Astro.props
const { collection, data, body } = entry
const { title, summary, date } = data
const source = collection === "blog" ? data.source : null

const demoUrl = collection === "projects" ? data.demoUrl : null
const repoUrl = collection === "projects" ? data.repoUrl : null
---

<div>
  <a href={`/${collection}`} class="group w-fit label px-3 py-1.5 flex items-center gap-2 border rounded-full transition-colors duration-300 ease-in-out hover:bg-paper-raised" style="border-color: var(--paper-line);">
    <span aria-hidden="true">&#8592;</span>
    <span>Volver a {collection}</span>
  </a>
  <div class="flex flex-wrap font-mono text-xs uppercase tracking-wide mt-10 gap-x-3 gap-y-1" style="color: var(--ink-faint);">
    {source && <span style="color: var(--river-deep);">{source}</span>}
    <span>{formatDate(date)}</span>
    <span>·</span>
    <span>{readingTime(body)}</span>
  </div>
  <h1 class="serif italic text-3xl md:text-4xl mt-2" style="color: var(--ink);">
    {title}
  </h1>
  <div class="mt-2" style="color: var(--ink-soft);">
    {summary}
  </div>
  {(demoUrl || repoUrl) &&
  <div class="mt-4 flex flex-wrap gap-2">
    {demoUrl &&
      <a href={demoUrl} target="_blank" class="label flex gap-2 items-center px-3 py-1.5 rounded-full border transition-colors hover:bg-paper-raised" style="border-color: var(--paper-line);">
        Ver demo
      </a>
    }
    {repoUrl &&
      <a href={repoUrl} target="_blank" class="label flex gap-2 items-center px-3 py-1.5 rounded-full border transition-colors hover:bg-paper-raised" style="border-color: var(--paper-line);">
        Ver repositorio
      </a>
    }
  </div>
  }
</div>
